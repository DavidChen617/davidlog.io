{
  "name": "davidlog.io",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node scripts/gen-manifest.mjs && ng serve",
    "build": "node scripts/gen-manifest.mjs && ng build",
    "build:gh-pages": "node scripts/gen-manifest.mjs && ng build --configuration github-pages && node scripts/prepare-gh-pages.mjs",
    "gh-pages:prepare": "node scripts/prepare-gh-pages.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "artifacts": "node scripts/artifacts.mjs"
  },
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "marked": "^17.0.6",
    "mermaid": "^11.14.0",
    "ngx-markdown": "^21.1.0",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/typography": "^0.5.19",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2"
  }
}
